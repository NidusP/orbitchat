{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@orbitchat/shared-types": ["packages/shared-types/src"],
      "@orbitchat/shared-types/*": ["packages/shared-types/src/*"],
      "@orbitchat/shared-utils": ["packages/shared-utils/src"],
      "@orbitchat/shared-utils/*": ["packages/shared-utils/src/*"],
      "@orbitchat/ui": ["packages/ui/src"],
      "@orbitchat/ui/*": ["packages/ui/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
