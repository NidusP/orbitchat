{
  "name": "orbitchat",
  "version": "0.0.1",
  "private": true,
  "description": "A social platform for learning modern full-stack TypeScript development with AI collaboration (Agentic Engineering)",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "keywords": [
    "social",
    "platform",
    "typescript",
    "full-stack",
    "learning",
    "agentic-engineering"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  }
}
