# Docker Compose 本地基础设施（复制为 .env 后使用）
# docker compose up -d

POSTGRES_USER=orbitchat
POSTGRES_PASSWORD=orbitchat
POSTGRES_DB=orbitchat
POSTGRES_PORT=5432

REDIS_PORT=6379

# apps/server/.env 中 DATABASE_URL 需与上方一致：
# DATABASE_URL=postgresql://orbitchat:orbitchat@localhost:5432/orbitchat
#
# Phase 3+ 可选 Redis（当前代码未使用）：
# REDIS_URL=redis://localhost:6379
