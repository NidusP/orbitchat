{
  "name": "@orbitchat/server",
  "version": "0.0.1",
  "private": true,
  "description": "Orbitchat backend server (Bun + Hono)",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun run src/index.ts",
    "start": "bun src/index.ts",
    "lint": "eslint src --max-warnings 0",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:reset-dev-user": "bun scripts/reset-dev-test-user.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.0",
    "@orbitchat/shared-types": "workspace:*",
    "@orbitchat/shared-utils": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.12.0",
    "postgres": "^3.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.0",
    "@types/node": "^20.18.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
